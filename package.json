{
  "name": "typebar",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n \"Vite,TSC,Electron\" -c \"blue,green,magenta\" \"vite\" \"tsc -p tsconfig.electron.json -w\" \"electron .\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:vite && npm run build:electron",
    "compile-hook": "dotnet publish keyboard-hook/TypeBarHook.csproj -c Release -r win-x64 -p:PublishSingleFile=true --self-contained true -o keyboard-hook/publish",
    "dist": "npm run compile-hook && npm run build && electron-builder",
    "lint": "eslint ."
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.typebar.assistant",
    "productName": "TypeBar",
    "directories": {
      "output": "dist-packaged"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TypeBar",
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "keyboard-hook/publish/TypeBarHook.exe",
        "to": "TypeBarHook.exe"
      }
    ]
  }
}
